# Configuración de Producción
DB_PATH=korzadivpn.db
PORT=8080
# Clave robusta para JWT (Minimo 32 caracteres)
JWT_SECRET=<GENERAR_UN_SECRET_SEGURO_DE_32_O_MAS_CARACTERES>
# Clave para cifrado AES-256 (64 caracteres hexadecimales = 32 bytes)
ENCRYPTION_KEY=<GENERAR_UNA_CLAVE_HEX_DE_64_CARACTERES>
# WireGuard Interface
WG_INTERFACE=wg0
